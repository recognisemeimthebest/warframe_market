# Web server
WEB_HOST=0.0.0.0
WEB_PORT=9000

# 관리자
ADMIN_PASSWORD=your_password_here

# Web Push VAPID (생성: python -c "from py_vapid import Vapid; v=Vapid(); v.generate_keys(); print(v.public_key, v.private_key)")
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_EMAIL=your@email.com

# Logging
LOG_LEVEL=INFO
